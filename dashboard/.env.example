# =============================================================================
# Phone Server Dashboard — Environment Configuration
# Copy to .env and edit before deploy: cp .env.example .env
# =============================================================================

# --- Core ---
NODE_ENV=production
PORT=3000
BIND_HOST=127.0.0.1
BASE_DOMAIN=aniketdutta.space

# --- Auth (CHANGE BEFORE DEPLOY) ---
ADMIN_USER=admin
ADMIN_PASSWORD=changeme
SESSION_SECRET=generate-a-64-character-random-string-here

# --- Cloudflare Tunnel ---
TUNNEL_NAME=phone-tunnel
TUNNEL_ID=

# --- Paths (Termux defaults) ---
HOME_DIR=/data/data/com.termux/files/home
PROJECTS_FRONTEND=/data/data/com.termux/files/home/projects/frontend
PROJECTS_BACKEND=/data/data/com.termux/files/home/projects/backend
UPLOADS_DIR=/data/data/com.termux/files/home/uploads
CLOUDFLARED_BIN=/data/data/com.termux/files/home/cloudflared
CLOUDFLARED_CONFIG=/data/data/com.termux/files/home/.cloudflared/config.yml

# --- Project port allocation ---
# Every uploaded/cloned app gets one unique port from this range.
# Reserved ports are never assigned to projects.
PROJECT_PORT_START=3001
PROJECT_PORT_END=3999
RESERVED_PORTS=3000,5432,8080

# --- PostgreSQL (runs on phone) ---
PGDATA=/data/data/com.termux/files/home/postgres-data
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=
PGDATABASE=postgres

# --- Remote DB (pick one) ---
# Tailscale (recommended): phone Tailscale IP — direct connect from Mac, no cloudflared
DB_PUBLIC_HOST=100.x.x.x
# Cloudflare TCP tunnel (needs cloudflared on every client):
# DB_PUBLIC_HOST=db.aniketdutta.space
DB_PUBLIC_PORT=5432

# --- Security ---
TRUST_PROXY=true
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW_MS=60000
UPLOAD_MAX_MB=100
